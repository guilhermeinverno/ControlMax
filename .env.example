# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase — use variáveis VITE_* abaixo ou copie firebase-applet-config.example.json
# para firebase-applet-config.json em backend/ e frontend/ (sem commitar a API key).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# ID do banco Firestore (não-default). Obrigatório na Vercel se não houver firebase-applet-config.json local.
VITE_FIRESTORE_DATABASE_ID=""

# URL base do backend Express em produção (ex.: https://api.seudominio.com).
# Em desenvolvimento, o proxy do Vite encaminha /api para localhost:3000.
VITE_API_URL=""

# Seed do usuário de QA (backend/scripts/seedQaUser.ts) — opcional
# GOOGLE_APPLICATION_CREDENTIALS="/caminho/para/service-account.json"
# QA_USER_EMAIL="qa@controlmax.dev"
# QA_USER_PASSWORD="ControlMax-QA-2026!"
